# ===========================================
# KDS TRACKER - VARIÁVEIS DE AMBIENTE
# ===========================================
# Copie este arquivo para .env e preencha os valores
# ===========================================

# Banco de Dados SQLite
DATABASE_URL="file:./prisma/godmode.db"

# NextAuth - URL pública do servidor
# Exemplo: https://kds-tracker.seu-dominio.com
NEXTAUTH_URL="https://SEU_DOMINIO.easypanel.host"

# NextAuth - Chave secreta para criptografar sessões
# Gere uma nova em: https://generate-secret.vercel.app/
NEXTAUTH_SECRET="GERE_SUA_CHAVE_AQUI"

# Firebase (opcional - para analytics em tempo real)
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""
# NEXT_PUBLIC_FIREBASE_API_KEY=""
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=""

# Gemini AI (opcional - configurável por workspace no dashboard)
# GEMINI_API_KEY=""
